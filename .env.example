# ---------------------------------------------------------------------------
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env al control de versiones.
# ---------------------------------------------------------------------------

# Django
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=liquidador
POSTGRES_USER=liquidador
POSTGRES_PASSWORD=cambia-esta-password-segura
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Correo IMAP (bandeja donde llegan las carpetas)
# Ejemplo Gmail: IMAP_HOST=imap.gmail.com  (requiere App Password)
# Ejemplo Outlook: IMAP_HOST=outlook.office365.com
# ---------------------------------------------------------------------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=tu-correo@gmail.com
IMAP_PASSWORD=tu-app-password-aqui
IMAP_FOLDER=INBOX

# ---------------------------------------------------------------------------
# Google Gemini (pipeline IA)
# Obtén tu API key en: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=tu-gemini-api-key-aqui

# ---------------------------------------------------------------------------
# Microservicio ia-liquidador
# URL interna Docker (si se usan ambos docker-compose en una misma red: "ia")
# URL externa si corren por separado: http://localhost:8001
# ---------------------------------------------------------------------------
IA_LIQUIDADOR_URL=http://ia:8001
IA_LIQUIDADOR_API_KEY=tu-api-key-del-microservicio
